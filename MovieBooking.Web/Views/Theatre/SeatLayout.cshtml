@* Views/Theatre/SeatLayout.cshtml — Visual seat grid for a screen *@
@model Dictionary<string, List<MovieBooking.Models.Seat>>
@{
    ViewData["Title"] = "Seat Layout";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var screen = ViewBag.Screen as MovieBooking.Models.Screen;
    var theatre = ViewBag.Theatre as MovieBooking.Models.Theatre;
}

<div class="container">
    <div class="form-page-header">
        <a asp-action="Screens" asp-controller="Theatre"
           asp-route-id="@theatre?.TheatreId" class="back-link">← Back to Screens</a>
        <div>
            <h1 class="page-title">💺 Seat Layout</h1>
            <p style="color:var(--text-muted);margin-top:.2rem">
                @theatre?.Name · @screen?.ScreenName
                <span class="badge-sm" style="margin-left:.5rem">@screen?.ScreenType</span>
            </p>
        </div>
    </div>

    @* Stats row *@
    @{
        var allSeats = Model.Values.SelectMany(s => s).ToList();
        var vipCount      = allSeats.Count(s => s.Category == "VIP");
        var premiumCount  = allSeats.Count(s => s.Category == "Premium");
        var standardCount = allSeats.Count(s => s.Category == "Standard");
    }

    <div style="display:flex;gap:1rem;margin-bottom:2rem;flex-wrap:wrap">
        <div class="card" style="flex:1;min-width:120px;text-align:center;padding:1rem">
            <div style="font-size:1.5rem;font-weight:800;color:var(--text)">@allSeats.Count</div>
            <div style="font-size:.75rem;color:var(--text-muted);font-weight:500">Total Seats</div>
        </div>
        <div class="card" style="flex:1;min-width:120px;text-align:center;padding:1rem;border-top:3px solid #e8344a">
            <div style="font-size:1.5rem;font-weight:800;color:#e8344a">@vipCount</div>
            <div style="font-size:.75rem;color:var(--text-muted);font-weight:500">VIP</div>
        </div>
        <div class="card" style="flex:1;min-width:120px;text-align:center;padding:1rem;border-top:3px solid #6366f1">
            <div style="font-size:1.5rem;font-weight:800;color:#6366f1">@premiumCount</div>
            <div style="font-size:.75rem;color:var(--text-muted);font-weight:500">Premium</div>
        </div>
        <div class="card" style="flex:1;min-width:120px;text-align:center;padding:1rem;border-top:3px solid #10b981">
            <div style="font-size:1.5rem;font-weight:800;color:#10b981">@standardCount</div>
            <div style="font-size:.75rem;color:var(--text-muted);font-weight:500">Standard</div>
        </div>
    </div>

    @* SEAT GRID *@
    <div class="card" style="overflow-x:auto">

        @* Screen bar *@
        <div style="background:var(--dark);color:rgba(255,255,255,.5);text-align:center;padding:.5rem 2rem;border-radius:var(--radius-sm);margin-bottom:2rem;font-size:.75rem;letter-spacing:.15em;max-width:600px;margin-left:auto;margin-right:auto">
            ▬▬▬▬▬▬▬▬▬ SCREEN ▬▬▬▬▬▬▬▬▬
        </div>

        <div style="overflow-x:auto;padding-bottom:1rem">
            @foreach (var row in Model)
            {
                var firstSeat = row.Value.FirstOrDefault();
                var category = firstSeat?.Category ?? "Standard";
                var (rowColor, rowBg) = category switch {
                    "VIP"     => ("#e8344a", "#fff0f2"),
                    "Premium" => ("#6366f1", "#eef2ff"),
                    _         => ("#10b981", "#f0fdf4")
                };

                <div class="seat-row">
                    @* Row label *@
                    <div class="row-label" style="color:@rowColor">@row.Key</div>

                    @* Category pill *@
                    <div class="row-category" style="color:@rowColor;background:@rowBg">
                        @category
                    </div>

                    @* Seats *@
                    <div class="seats-group">
                        @foreach (var seat in row.Value)
                        {
                            <div class="seat-box @category.ToLower()"
                                 title="@row.Key@seat.SeatNumber — @category — ₹@seat.BasePrice">
                                @seat.SeatNumber
                            </div>
                        }
                    </div>

                    @* Price *@
                    <div class="row-price" style="color:@rowColor">₹@firstSeat?.BasePrice</div>
                </div>
            }
        </div>

        @* Legend *@
        <div style="display:flex;gap:1.5rem;padding-top:1.5rem;border-top:1px solid var(--border);flex-wrap:wrap">
            <div style="display:flex;align-items:center;gap:.5rem;font-size:.8rem">
                <div style="width:24px;height:24px;background:#fff0f2;border:1.5px solid #e8344a;border-radius:4px"></div>
                <span>VIP</span>
            </div>
            <div style="display:flex;align-items:center;gap:.5rem;font-size:.8rem">
                <div style="width:24px;height:24px;background:#eef2ff;border:1.5px solid #6366f1;border-radius:4px"></div>
                <span>Premium</span>
            </div>
            <div style="display:flex;align-items:center;gap:.5rem;font-size:.8rem">
                <div style="width:24px;height:24px;background:#f0fdf4;border:1.5px solid #10b981;border-radius:4px"></div>
                <span>Standard</span>
            </div>
        </div>
    </div>
</div>

<style>
.seat-row { display:flex; align-items:center; gap:.75rem; margin-bottom:6px; min-width:max-content; }
.row-label { width:20px; font-size:.825rem; font-weight:700; flex-shrink:0; text-align:center; }
.row-category { font-size:.65rem; font-weight:600; padding:.15rem .5rem; border-radius:999px; flex-shrink:0; min-width:58px; text-align:center; letter-spacing:.03em; }
.seats-group { display:flex; gap:4px; flex-wrap:nowrap; }
.seat-box { width:26px; height:26px; border-radius:4px; display:flex; align-items:center; justify-content:center; font-size:.62rem; font-weight:600; cursor:default; border:1.5px solid; flex-shrink:0; transition:transform .1s; }
.seat-box:hover { transform:scale(1.15); }
.seat-box.vip      { background:#fff0f2; border-color:#e8344a; color:#c0253a; }
.seat-box.premium  { background:#eef2ff; border-color:#6366f1; color:#4338ca; }
.seat-box.standard { background:#f0fdf4; border-color:#10b981; color:#065f46; }
.row-price { font-size:.75rem; font-weight:600; flex-shrink:0; min-width:50px; }
</style>
