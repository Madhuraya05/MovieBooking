@model MovieBooking.Web.Models.TheatreViewModel
@{
    ViewData["Title"] = "Edit Theatre";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="container">
    <div class="form-page-header">
        <a asp-action="Manage" asp-controller="Theatre" class="back-link">← Back to Theatres</a>
        <h1 class="page-title">✏ Edit Theatre</h1>
    </div>
    <div class="form-card">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
        <form asp-action="Edit" asp-controller="Theatre" asp-route-id="@Model.TheatreId" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="TheatreId" />
            <div class="form-grid-2">
                <div class="form-group">
                    <label asp-for="Name" class="form-label"></label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>
                <div class="form-group">
                    <label asp-for="City" class="form-label"></label>
                    <input asp-for="City" class="form-control" />
                    <span asp-validation-for="City" class="text-danger small"></span>
                </div>
                <div class="form-group">
                    <label asp-for="PhoneNumber" class="form-label"></label>
                    <input asp-for="PhoneNumber" class="form-control" />
                    <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                </div>
            </div>
            <div class="form-group">
                <label asp-for="Address" class="form-label"></label>
                <textarea asp-for="Address" class="form-control" rows="2"></textarea>
                <span asp-validation-for="Address" class="text-danger small"></span>
            </div>
            <div class="form-actions">
                <a asp-action="Screens" asp-controller="Theatre"
                   asp-route-id="@Model.TheatreId" class="btn-secondary">Cancel</a>
                <button type="submit" class="btn-primary">Save Changes</button>
            </div>
        </form>
    </div>
</div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
