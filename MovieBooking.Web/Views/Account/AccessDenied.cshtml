@* Views/Account/AccessDenied.cshtml *@
@{
    ViewData["Title"] = "Access Denied";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="auth-wrapper">
    <div class="auth-card" style="text-align:center;">
        <div style="font-size:4rem; margin-bottom:1rem;">🚫</div>
        <h1 style="color:#e53e3e; margin-bottom:0.5rem;">Access Denied</h1>
        <p style="color:#718096; margin-bottom:2rem;">
            You don't have permission to view this page.
            This area is restricted to specific roles.
        </p>
        <a asp-action="Index" asp-controller="Home" class="btn-auth" style="display:inline-block; text-decoration:none;">
            Go Back Home
        </a>
    </div>
</div>
